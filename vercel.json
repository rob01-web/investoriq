{
  "version": 2,
  "functions": {
    "api/admin-run-worker.js": { "maxDuration": 300 },
    "api/**/*.js": { "maxDuration": 60 }
  },
  
  "routes": [
    { "handle": "filesystem" },

    { "src": "^/api/(.*)$", "dest": "/api/$1" },

    { "src": "^/assets/(.*)$", "dest": "/assets/$1" },

    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
